# Gemini API Key (Required for AI operations: OCR receipt extraction & recommendations)
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# MongoDB Connection String (Optional: falls back to local data_db.json file if not provided/connected)
DATABASE_URL="mongodb://localhost:27017"

# Default configuration for retro CRT screen styles (Note: Frontend VITE_ prefix required on client)
# VITE_DEFAULT_CRT_ENABLED=false
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://127.0.0.1:8000